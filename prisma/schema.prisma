generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  OWNER
}

enum BotStatus {
  LIVE
  BETA
  MAINTENANCE
  PAUSED
}

enum PlanType {
  FREE
  PAID
  FREEMIUM
  CUSTOM
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
  PAYPAL
  MANUAL
  UPI
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  FAILED
  REFUNDED
}

model User {
  id            String            @id @default(cuid())
  email         String?           @unique
  passwordHash  String?
  discordId     String?           @unique
  discordTag    String?
  avatarUrl     String?
  role          UserRole          @default(USER)
  isBanned      Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  sessions      Session[]
  guildMembers  GuildMember[]
  subscriptions Subscription[]
  payments      Payment[]
  freeGrants    FreeAccessGrant[]
  trialGrants   TrialGrant[]
  auditLogs     AuditLog[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Guild {
  id               String            @id @default(cuid())
  internalCode     String            @unique
  discordGuildId   String            @unique
  name             String
  ownerDiscordId   String?
  onboardingDone   Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  members          GuildMember[]
  installs         GuildBotInstall[]
  subscriptions    Subscription[]
  payments         Payment[]
  featureFlags     FeatureFlag[]
  welcomeSettings  WelcomeSetting?
  moderationSettings ModerationSetting?
  automodSettings  AutomodSetting?
  youtubeSettings  YoutubeSetting?
  musicSettings    MusicSetting?
  levelSettings    LevelSetting?
  ticketSettings   TicketSetting?
  aiSettings       AISetting?
}

model GuildMember {
  id         String @id @default(cuid())
  guildId    String
  userId     String
  isOwner    Boolean @default(false)
  canManage  Boolean @default(false)
  guild      Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
}

model BotConfig {
  id              String    @id @default(cuid())
  key             String    @unique
  slug            String    @unique
  name            String
  description     String
  category        String
  inviteUrl       String
  clientId        String
  tokenSecret     String
  status          BotStatus @default(LIVE)
  planType        PlanType  @default(FREEMIUM)
  monthlyPrice    Decimal   @default(0)
  yearlyPrice     Decimal   @default(0)
  lifetimePrice   Decimal?
  featureList     Json
  premiumFeatures Json
  logoUrl         String?
  showOnWebsite   Boolean   @default(true)
  showOnDashboard Boolean   @default(true)
  disabled        Boolean   @default(false)
  dashboardRoute  String
  installs        GuildBotInstall[]
  pricingRules    PricingRule[]
  subscriptions   Subscription[]
}

model GuildBotInstall {
  id          String   @id @default(cuid())
  guildId     String
  botConfigId String
  installedAt DateTime @default(now())
  active      Boolean  @default(true)
  guild       Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  botConfig   BotConfig @relation(fields: [botConfigId], references: [id], onDelete: Cascade)

  @@unique([guildId, botConfigId])
}

model PremiumPlan {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String
  monthly     Decimal
  yearly      Decimal
  lifetime    Decimal?
  features    Json
  active      Boolean @default(true)
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String
  guildId       String
  botConfigId   String?
  planCode      String
  startedAt     DateTime @default(now())
  expiresAt     DateTime?
  graceUntil    DateTime?
  isTrial       Boolean  @default(false)
  isPremium     Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild         Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  botConfig     BotConfig? @relation(fields: [botConfigId], references: [id], onDelete: SetNull)

  @@index([guildId, botConfigId])
  @@index([userId, startedAt])
}

model Payment {
  id          String          @id @default(cuid())
  userId      String
  guildId     String
  botKey      String
  planCode    String
  provider    PaymentProvider
  amount      Decimal
  status      PaymentStatus   @default(PENDING)
  referenceId String?
  metadata    Json?
  createdAt   DateTime        @default(now())
  reviewedAt  DateTime?
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild       Guild           @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model FeatureFlag {
  id       String  @id @default(cuid())
  guildId  String
  botKey   String
  flag     String
  enabled  Boolean @default(false)
  guild    Guild   @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, botKey, flag])
}

model FreeAccessGrant {
  id           String   @id @default(cuid())
  userId        String
  guildId       String?
  botKey        String?
  reason        String
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TrialGrant {
  id           String   @id @default(cuid())
  userId        String
  guildId       String?
  botKey        String?
  days          Int
  createdAt     DateTime @default(now())
  used          Boolean  @default(false)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PricingRule {
  id               String  @id @default(cuid())
  botConfigId      String
  planCode         String
  yearlyDiscount   Int     @default(0)
  trialDurationDays Int    @default(0)
  freemiumEnabled  Boolean @default(true)
  botConfig        BotConfig @relation(fields: [botConfigId], references: [id], onDelete: Cascade)
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Int
  active          Boolean  @default(true)
  maxUses         Int?
  usedCount       Int      @default(0)
  expiresAt       DateTime?
}

model AuditLog {
  id         String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String
  payload     Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AnalyticsSnapshot {
  id           String   @id @default(cuid())
  dateKey      String   @unique
  totalUsers   Int
  totalGuilds  Int
  activeTrials Int
  mrr          Decimal
  createdAt    DateTime @default(now())
}

model WelcomeSetting {
  id            String @id @default(cuid())
  guildId       String @unique
  welcomeText   String
  goodbyeText   String
  dmEnabled     Boolean @default(false)
  autoroleIds   Json
  verification  Boolean @default(false)
  guild         Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model ModerationSetting {
  id          String @id @default(cuid())
  guildId     String @unique
  logChannelId String?
  warnDecayDays Int @default(30)
  antiRaidEnabled Boolean @default(true)
  guild       Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model AutomodSetting {
  id              String @id @default(cuid())
  guildId         String @unique
  spamFilter      Boolean @default(true)
  scamFilter      Boolean @default(true)
  inviteFilter    Boolean @default(false)
  phishingFilter  Boolean @default(true)
  mentionLimit    Int @default(5)
  guild           Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model YoutubeSetting {
  id               String @id @default(cuid())
  guildId          String @unique
  trackedChannels  Json
  notifyChannelId  String?
  fastSync         Boolean @default(false)
  guild            Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model MusicSetting {
  id            String @id @default(cuid())
  guildId       String @unique
  djRoleId      String?
  autoplay      Boolean @default(false)
  hqAudio       Boolean @default(false)
  queueLimit    Int @default(50)
  guild         Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model LevelSetting {
  id               String @id @default(cuid())
  guildId          String @unique
  xpPerMessageMin  Int @default(8)
  xpPerMessageMax  Int @default(20)
  voiceXpEnabled   Boolean @default(false)
  multipliers      Json
  ignoredChannels  Json
  guild            Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model TicketSetting {
  id               String @id @default(cuid())
  guildId          String @unique
  panelConfig      Json
  transcriptEnabled Boolean @default(true)
  maxOpenTickets   Int @default(2)
  guild            Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}

model AISetting {
  id                  String @id @default(cuid())
  guildId             String @unique
  autoSuggestions     Boolean @default(false)
  safetyAssist        Boolean @default(true)
  responsePersona     String @default("helpful")
  guild               Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
}
